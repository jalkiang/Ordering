<!--pages/test/test.wxml-->
<view class="page">
  <view class="counter">
    <button class="circle-btn" bindtap="decrease" aria-label="减少">
      <text class="icon minus"></text>
    </button>
    <text class="count">{{count}}</text>
    <button class="circle-btn" bindtap="increase" aria-label="增加">
      <text class="icon plus"></text>
    </button>
  </view>
</view>