.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 20rpx;
  box-sizing: border-box;
  margin-bottom: 200rpx;
}

.header {
  margin-bottom: 16rpx;
}

.title {
  font-size: 34rpx;
  color: #222;
  font-weight: 700;
}

.store-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.status-tabs {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.tabs-inner {
  display: inline-flex;
  gap: 12rpx;
}

.tab-item {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #666;
  font-size: 24rpx;
}

.tab-item.active {
  background: #07c160;
  color: #fff;
}

.loading,
.empty {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 26rpx;
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 70rpx 18rpx;
  margin-bottom: 33rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.store-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  max-width: 70%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f2f2;
  color: #666;
}

.status.pending {
  background: #fff4e5;
  color: #f59e0b;
}

.status.cooking {
  background: #e8f2ff;
  color: #2563eb;
}

.status.completed {
  background: #e9f9ef;
  color: #16a34a;
}

.status.cancelled {
  background: #f7f7f7;
  color: #999;
}

.order-meta {
  margin-top: 8rpx;
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #666;
}

.row-between {
  justify-content: space-between;
}

.goods-line {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price {
  color: #ff4d4f;
  font-weight: 600;
}