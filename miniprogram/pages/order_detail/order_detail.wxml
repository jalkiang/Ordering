<view class="page" wx:if="{{order}}">
  <view class="card">
    <view class="header">
      <view class="order-no">订单号：{{order.order_no}}</view>
      <view class="status {{order.order_status}}">{{order.status_text}}</view>
    </view>
    <view class="meta">门店：{{order.store_name || '-'}}</view>
    <view class="meta">桌号：{{order.table_no || '-'}}</view>
    <view class="meta">下单时间：{{order.created_at_text}}</view>
    <view class="meta">支付状态：{{order.pay_text}}</view>
    <view class="meta">备注：{{order.remark || '无'}}</view>
  </view>

  <view class="card">
    <view class="section-title">商品明细</view>
    <view wx:for="{{order.items}}" wx:key="index" class="item-row">
      <view class="item-main">
        <view class="item-name">{{item.food_name}}</view>
        <view class="item-spec" wx:if="{{item.spec_key}}">{{item.spec_key}}</view>
      </view>
      <view class="item-right">
        <view class="item-qty">x{{item.quantity}}</view>
        <view class="item-price">¥{{item.total_price}}</view>
      </view>
    </view>
    <view class="total-line">
      <text>菜品数量：{{order.item_count}}</text>
      <text class="total-price">合计：¥{{order.payable_amount}}</text>
    </view>
  </view>

  <view class="actions">
    <button wx:if="{{order.can_pay}}" class="action-btn pay" data-action="pay" bindtap="onActionTap">
      去支付
    </button>
    <button wx:if="{{order.can_cancel}}" class="action-btn cancel" data-action="cancel" bindtap="onActionTap">
      取消订单
    </button>
  </view>
</view>

<view class="empty" wx:if="{{!loading && !order}}">订单不存在或无权限查看</view>
