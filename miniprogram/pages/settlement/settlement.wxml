<view class="page">
  <view class="card">
    <view class="card-title">用餐信息</view>
    <view class="row">
      <text class="label">门店</text>
      <text class="value">{{context.store_name || '-'}}</text>
    </view>
    <view class="row">
      <text class="label">桌台</text>
      <text class="value">{{context.table_no || '-'}}</text>
    </view>
    <view class="row">
      <text class="label">就餐人数</text>
      <input
        class="people-input"
        type="number"
        value="{{peopleCount}}"
        bindinput="onPeopleCountInput"
      />
    </view>
    <view class="remark">
      <text class="label">备注</text>
      <textarea
        class="remark-input"
        maxlength="100"
        placeholder="例如：少辣、先上饮品"
        bindinput="onRemarkInput"
        value="{{remark}}"
      />
    </view>
  </view>

  <view class="card">
    <view class="card-title">商品清单</view>
    <block wx:for="{{cartList}}" wx:key="food_id">
      <view class="item-row">
        <view class="item-main">
          <view class="item-name">{{item.name}}</view>
          <view class="item-price">¥{{item.price}} x {{item.quantity}}</view>
        </view>
        <view class="item-total">¥{{item.line_total}}</view>
      </view>
    </block>
  </view>

  <view class="bottom-bar">
    <view class="summary">
      <view class="count">共 {{totalCount}} 件</view>
      <view class="amount">¥{{totalPrice}}</view>
    </view>
    <button class="submit-btn" bindtap="onSubmitOrder" loading="{{submitting}}" disabled="{{submitting}}">
      提交订单
    </button>
  </view>
</view>
