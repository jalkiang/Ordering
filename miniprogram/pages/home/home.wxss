/* pages/home/home.wxss */
.container {
  width: 100%;
  min-height: 100vh;
  background: #f6f7fb;
}

.top {
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-section {
  width: 100%;
}

.swiper {
  width: 100%;
}

.swiper swiper {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.swiper swiper-item {
  width: 100%;
  height: 100%;
}

.banner-img {
  width: 100%;
  height: 100%;
  display: block;
}

.btn_order_food {
  margin: 24rpx;
  border-radius: 999rpx;
  background: #07c160;
  color: #fff;
}